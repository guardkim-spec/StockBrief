# ── AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── News ─────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here

# ── Gmail OAuth2 (JSON string from credentials.json) ─────────────────
GMAIL_OAUTH_TOKEN={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}
GMAIL_SENDER=your_email@gmail.com
GMAIL_RECIPIENT=your_email@gmail.com

# ── Google Sheets ─────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=your_google_sheets_spreadsheet_id
GOOGLE_SHEETS_NAME=StockBrief_v2
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Drive ──────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ── GitHub ────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=StockBrief
GITHUB_BRANCH=main

# ── App ───────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
